{
  "name": "mineradio-mobile",
  "version": "1.0.0",
  "description": "Mineradio 移动版 — 沉浸式音乐播放器",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node -e \"var f=require('fs'),p=require('path');['vendor','assets'].forEach(function(d){var s=p.join('public',d),t=p.join('www',d);if(f.existsSync(s)){f.mkdirSync(t,{recursive:true});f.readdirSync(s).forEach(function(x){f.copyFileSync(p.join(s,x),p.join(t,x))})}})\"",
    "sync": "npx cap sync",
    "open:android": "npx cap open android",
    "open:ios": "npx cap open ios",
    "build:android": "vite build && npx cap sync android",
    "build:ios": "vite build && npx cap sync ios"
  },
  "dependencies": {
    "@capacitor/android": "^7.3.0",
    "@capacitor/cli": "^7.3.0",
    "@capacitor/core": "^7.3.0",
    "@capacitor/ios": "^7.3.0",
    "crypto-js": "^4.2.0",
    "mpg123-decoder": "^1.0.3",
    "NeteaseCloudMusicApi": "^4.32.0"
  },
  "devDependencies": {
    "vite": "^7.3.0"
  }
}
